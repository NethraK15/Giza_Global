# AI Microservice Configuration
PORT=8000
LOG_LEVEL=INFO

# Model weights directory (relative to ai-service root)
MODEL_DIR=./models/yolo_weights

# Artifacts output directory
ARTIFACTS_PATH=./artifacts

# PDF conversion DPI
PDF_DPI=300

# Upload limits
MAX_FILE_SIZE_MB=5
ALLOWED_EXTENSIONS=["pdf","jpg","jpeg","png"]

# Detection thresholds
DETECTION_CONFIDENCE_THRESHOLD=0.25
NMS_IOU_THRESHOLD=0.45

# Line detection tuning
HOUGH_THRESHOLD=80
MIN_LINE_LENGTH=40
MAX_LINE_GAP=10

# Contour filtering
MIN_CONTOUR_AREA=100

# Graph generation — max distance (px) for a line endpoint to connect to a symbol
LINE_SYMBOL_PROXIMITY_PX=20
